    {
      "source": "9b847187-f684-4f35-bff8-fde6e5fd3be8",
      "target": "3c7e442f-7fcc-40a9-92ed-e025bf04fd03",
      "sourceSide": "top",
      "targetSide": "bottomleft"
    },
    {
      "source": "b5338255-a247-4355-b3ae-c5397f0f73ad",
      "target": "79185721-3c28-4fa2-9c9f-cce87b845706",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "Matsson's offer gives Shiv a concrete personal upside from the sale, activating her ambition."
    },
    {
      "source": "9b847187-f684-4f35-bff8-fde6e5fd3be8",
      "target": "79185721-3c28-4fa2-9c9f-cce87b845706",
      "sourceSide": "topright",
      "targetSide": "bottomleft",
      "notes": "Shiv knows she lacks the credentials to win the CEO role through the family route, making Matsson's side-door offer more appealing."
    },
    {
      "source": "d241b1dd-0b39-428e-a77d-d9fdfc88876e",
      "target": "b5338255-a247-4355-b3ae-c5397f0f73ad",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "Matsson wants a controllable U.S. figurehead; offering Shiv the role serves his need for a pliable ally inside the Roy family."
    },
    {
      "source": "0c41448d-3187-4de6-9609-5fe2f3ebf78f",
      "target": "f8e1db46-7964-41b7-99c0-cd6902b30d3d",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "The collapse of the marriage frees Tom to act purely in self-interest, making him willing to betray the Roy siblings to Matsson."
    },
    {
      "source": "f8e1db46-7964-41b7-99c0-cd6902b30d3d",
      "target": "d241b1dd-0b39-428e-a77d-d9fdfc88876e",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "Tom's inside information and demonstrated loyalty make him Matsson's ideal figurehead candidate."
    },
    {
      "source": "71acd8f7-f52d-4e69-9a8e-7f9d39221e3b",
      "target": "0c41448d-3187-4de6-9609-5fe2f3ebf78f",
      "sourceSide": "topleft",
      "targetSide": "bottomright",
      "confidence": "medium",
      "notes": "Logan's toxic parenting warped Shiv's capacity for trust and intimacy, contributing to the marriage's collapse."
    },
    {
      "source": "460a1e9a-e889-4dc4-9dca-efba0ac7d1b0",
      "target": "19b10185-f655-4baa-9806-6df270a34b68",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "The Cruises scandal directly triggers DOJ investigation and Congressional hearings, creating regulatory and political exposure."
    },
    {
      "source": "1a81bef9-cfb1-44df-b57e-e10745d170f1",
      "target": "83bc4a53-ae22-4528-bf7e-b355d69f7772",
      "sourceSide": "topright",
      "targetSide": "bottomleft",
      "notes": "Kendall's addiction history undermines board and sibling confidence in his ability to lead."
    },
    {
      "source": "eff7a9cf-a7a1-4e83-aa95-23581786e63a",
      "target": "83bc4a53-ae22-4528-bf7e-b355d69f7772",
      "sourceSide": "topleft",
      "targetSide": "bottomright",
      "notes": "The concealed waiter death is a ticking time-bomb that makes Kendall permanently blackmailable and unfit for scrutiny as CEO."
    },
    {
      "source": "f1c90017-e365-4f02-a713-6c34e321916e",
      "target": "83bc4a53-ae22-4528-bf7e-b355d69f7772",
      "sourceSide": "topleft",
      "targetSide": "bottomright",
      "confidence": "medium",
      "notes": "Sibling rivalry means neither Roman nor Shiv will back Kendall's leadership, leaving him without family support."
    },
    {
      "source": "83bc4a53-ae22-4528-bf7e-b355d69f7772",
      "target": "3c7e442f-7fcc-40a9-92ed-e025bf04fd03",
      "sourceSide": "top",
      "targetSide": "bottom",
      "notes": "Shiv's belief that Kendall is unfit to be CEO is a key reason she votes yes on the sale rather than hand him the company."
    }
  ],
