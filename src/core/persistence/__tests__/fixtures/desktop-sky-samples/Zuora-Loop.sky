    {
      "source": "c36e992c-41d6-450e-a32f-93dfc1e45d34",
      "target": "9d583344-5586-4865-bd27-e443aa1e546b",
      "sourceSide": "top",
      "targetSide": "right",
      "polarity": "positive",
      "delay": true,
      "notes": "More features adopted means deeper integration with ERP, CRM, payments, and revenue recognition — increasing lock-in over time"
    },
    {
      "source": "9d583344-5586-4865-bd27-e443aa1e546b",
      "target": "b00857e3-a861-4179-84b6-f18aef622c2b",
      "sourceSide": "top",
      "targetSide": "bottom",
      "polarity": "negative",
      "notes": "High switching costs suppress churn even when satisfaction dips — the pain of migration keeps customers on the platform"
    },
    {
      "source": "c36e992c-41d6-450e-a32f-93dfc1e45d34",
      "target": "03092bb3-e4e0-489f-9d6c-f272ccb96609",
      "sourceSide": "bottom",
      "targetSide": "top",
      "polarity": "positive",
      "notes": "The cruel irony: more powerful and configurable features make initial setup and upgrades more complex and time-consuming"
    },
    {
      "source": "03092bb3-e4e0-489f-9d6c-f272ccb96609",
      "target": "19fd4ea0-7f13-49b0-b16a-1611fa38fba2",
      "sourceSide": "right",
      "targetSide": "right",
      "polarity": "negative",
      "notes": "Long implementation timelines (9-12+ months) reduce win rates and deter prospects from even considering Zuora — simpler competitors win on time-to-value"
    },
    {
      "source": "03092bb3-e4e0-489f-9d6c-f272ccb96609",
      "target": "2784fdc4-bd23-4e38-82e1-a85fa82919c8",
      "sourceSide": "left",
      "targetSide": "bottom",
      "polarity": "negative",
      "notes": "Complex module upgrades slow upsell velocity — customers hesitate to adopt additional capabilities if each requires a mini-implementation project"
    },
    {
      "source": "52ffa97b-6912-4034-9dea-732bb83ad905",
      "target": "03092bb3-e4e0-489f-9d6c-f272ccb96609",
      "sourceSide": "left",
      "targetSide": "top",
      "polarity": "negative",
      "delay": true,
      "notes": "Investment can be directed at simplifying onboarding, improving APIs, building self-service tooling, and better documentation — but only if leadership prioritizes it over new features"
    },
    {
      "source": "c36e992c-41d6-450e-a32f-93dfc1e45d34",
      "target": "7e712268-b10a-4287-a149-0d243b945598",
      "sourceSide": "top",
      "targetSide": "bottom",
      "polarity": "positive",
      "delay": true,
      "notes": "A broader suite of available modules creates more cross-sell and adoption opportunities — but adoption lags availability"
    },
    {
      "source": "7e712268-b10a-4287-a149-0d243b945598",
      "target": "9d583344-5586-4865-bd27-e443aa1e546b",
      "sourceSide": "top",
      "targetSide": "bottom",
      "polarity": "positive",
      "notes": "Each additional module adopted deepens integration with ERP, CRM, payments — exponentially increasing the cost and risk of ripping out Zuora"
    },
    {
      "source": "7e712268-b10a-4287-a149-0d243b945598",
      "target": "2784fdc4-bd23-4e38-82e1-a85fa82919c8",
      "sourceSide": "left",
      "targetSide": "right",
      "polarity": "positive",
      "notes": "Each module adopted IS expansion revenue — and multi-product customers have higher usage growth rates across all modules"
    },
    {
      "source": "03092bb3-e4e0-489f-9d6c-f272ccb96609",
      "target": "7e712268-b10a-4287-a149-0d243b945598",
      "sourceSide": "right",
      "targetSide": "right",
      "polarity": "negative",
      "notes": "Implementation complexity for each new module discourages customers from adopting additional products — they've been burned by the last rollout"
    },
    {
      "source": "c36e992c-41d6-450e-a32f-93dfc1e45d34",
      "target": "6037c6b1-7429-48af-b9fc-41ad19fdbab9",
      "sourceSide": "right",
      "targetSide": "left",
      "polarity": "positive",
      "delay": true,
      "notes": "Better features directly strengthen Zuora's competitive differentiation and value proposition — this is the primary driver of why prospects choose Zuora over alternatives"
    },
